{
    "rewrites": [
        {
            "source": "/privacy-policy",
            "destination": "/privacy-policy/index.html"
        },
        {
            "source": "/terms-of-use",
            "destination": "/terms-of-use/index.html"
        },
        {
            "source": "/electronic-consent",
            "destination": "/electronic-consent/index.html"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "strict-origin-when-cross-origin"
                }
            ]
        }
    ]
}